# Primary AI provider: gemini | openai | rules
# rules = always use free rule-based mode (no paid API calls)
AI_PROVIDER=gemini

# Gemini (optional) — used when available
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# OpenAI (optional fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional: Rakuten Ichiba API application ID
RAKUTEN_APP_ID=

# Optional: canonical app URL used for Origin allowlisting
NEXT_PUBLIC_APP_URL=https://my-tool-bay.vercel.app
