# OpenAI (recommended) — server-side only, never expose to the browser
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Optional: Rakuten Ichiba API application ID
# Without this, the app still recommends products via Rakuten/Amazon search links.
RAKUTEN_APP_ID=

# Optional: canonical app URL used for Origin allowlisting
NEXT_PUBLIC_APP_URL=https://my-tool-bay.vercel.app
